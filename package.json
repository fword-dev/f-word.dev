{
  "private": true,
  "type": "module",
  "scripts": {
    "start": "eleventy --serve --quiet",
    "build": "rm -rf dist && eleventy",
    "test": "npm run editorconfig",
    "editorconfig": "editorconfig-checker",
    "deploy": "rsync --archive --verbose --compress --delete --delete-excluded --exclude '.DS_Store' --copy-links ./dist/ deploy@f-word.dev:/opt/sites/f-word.dev/public/"
  },
  "engines": {
    "node": ">=24"
  },
  "browserslist": [
    "baseline widely available, safari 15"
  ],
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "browserslist-to-esbuild": "^2.1.1",
    "editorconfig-checker": "^6.1.1",
    "esbuild": "^0.28.0",
    "html-minifier": "^4.0.0",
    "js-yaml": "^4.1.1",
    "lightningcss": "^1.32.0",
    "markdown-it-named-headings": "^1.1.0",
    "music-metadata": "11.12.3",
    "pretty-data": "^0.40.0",
    "vnu-jar": "^26.4.16"
  }
}
